<script>
const form=document.getElementById("reviewForm")
const list=document.getElementById("reviewList")

function loadReviews(){
const saved=JSON.parse(localStorage.getItem("sempiternalReviews")||"[]")
saved.forEach(r=>addReview(r))
}

function addReview(r){
const div=document.createElement("div")
div.className="review"
div.innerHTML=`<strong>${r.rating}</strong> \"${r.text}\"<br><span style='color:#9ca3af;font-size:14px'>— ${r.name}</span>`
list.prepend(div)
}

form.addEventListener("submit",e=>{
e.preventDefault()

const name=form.children[0].value
const rating=form.children[1].value
const text=form.children[2].value

const review={name,rating,text}

let saved=JSON.parse(localStorage.getItem("sempiternalReviews")||"[]")
saved.push(review)
localStorage.setItem("sempiternalReviews",JSON.stringify(saved))

addReview(review)
form.reset()
})

loadReviews()


/* before after slider */
const slider=document.getElementById("slider")
if(slider){
const after=document.querySelector(".after")
slider.addEventListener("input",e=>{
after.style.width=e.target.value+"%"
})
}


</script>

