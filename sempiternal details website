*{box-sizing:border-box}
body{margin:0;font-family:'Poppins',sans-serif;background:#0b0f19;color:white}

header{background:rgba(10,12,20,.9);backdrop-filter:blur(8px);padding:20px;text-align:center;position:sticky;top:0;border-bottom:1px solid rgba(255,255,255,.08)}
