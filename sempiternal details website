.section h2{text-align:center;margin-bottom:50px;font-size:34px;font-weight:700}

.services{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:25px}

.card{background:linear-gradient(145deg,#111827,#030712);padding:30px;border-radius:14px;border:1px solid rgba(255,255,255,.06);transition:.25s}
.card:hover{transform:translateY(-6px);box-shadow:0 15px 35px rgba(0,0,0,.5)}
.card h3{margin-top:0;font-weight:600}

.price{font-size:34px;margin:12px 0 8px 0;color:#60a5fa;font-weight:700}
.tiers{color:#9ca3af;font-size:14px;line-height:1.6;margin-top:4px}

.gallery-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px}
.gallery-grid img{width:100%;border-radius:10px;border:1px solid rgba(255,255,255,.08)}

.review{background:linear-gradient(145deg,#111827,#030712);padding:22px;border-radius:12px;margin-bottom:15px;border:1px solid rgba(255,255,255,.06)}

.contact{background:#020617;text-align:center;border-top:1px solid rgba(255,255,255,.08)}

form{max-width:500px;margin:auto;display:flex;flex-direction:column;gap:12px}

input,textarea,select{padding:12px;border-radius:6px;border:1px solid rgba(255,255,255,.1);background:#020617;color:white}

button{padding:14px;border:none;background:linear-gradient(135deg,#3b82f6,#2563eb);color:white;border-radius:8px;font-weight:600;cursor:pointer}

.map{margin-top:40px;border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,.08)}

footer{text-align:center;padding:25px;background:#020617;color:#6b7280;border-top:1px solid rgba(255,255,255,.08)}

/* Floating Text Button */
.floating-text{
position:fixed;
bottom:25px;
right:25px;
background:#2563eb;
color:white;
padding:14px 18px;
border-radius:50px;
font-weight:600;
text-decoration:none;
