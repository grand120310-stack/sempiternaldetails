.btn{display:inline-block;margin-top:25px;padding:14px 34px;background:linear-gradient(135deg,#3b82f6,#2563eb);color:white;border-radius:8px;text-decoration:none;font-weight:600;box-shadow:0 10px 25px rgba(59,130,246,.35);transition:.25s}
